<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Contrapunto UY — Digest diario de Uruguay</title>
  <meta name="description" content="El digest diario de Uruguay. Noticias de los principales medios comparadas y analizadas con IA.">
  <meta name="robots" content="index, follow">
  <link rel="canonical" href="{{ base_url }}/">
  <meta property="og:title" content="Contrapunto UY">
  <meta property="og:description" content="El digest diario de Uruguay. Noticias comparadas con análisis de sesgo.">
  <meta property="og:type" content="website">
  <meta property="og:url" content="{{ base_url }}/">
  <link rel="stylesheet" href="assets/css/style.css">
</head>
<body>

<header id="site-header">
  <div class="header-inner">
    <div class="header-brand">
      <span class="brand-name">Contrapunto<span class="brand-accent">UY</span></span>
      <span class="brand-sep">·</span>
      <span class="brand-date sans">{{ last_update_date }}</span>
    </div>
    <p class="brand-tagline sans">Digest diario · {{ total_stories }} noticias · {{ total_sources }} medios</p>
  </div>
</header>

<main>
  {% if stories %}

  {# Group stories by category #}
  {% set categories = [] %}
  {% for story in stories %}
    {% if story.category not in categories %}
      {% set _ = categories.append(story.category) %}
    {% endif %}
  {% endfor %}

  {% for cat in categories %}
  <section class="category-section">
    <div class="category-header">
      <span class="category-label sans">{{ cat }}</span>
    </div>

    {% for story in stories if story.category == cat %}
    <article class="story-card" id="{{ story.id }}">

      <h2 class="story-topic">{{ story.topic }}</h2>

      <!-- Versión objetiva -->
      <div class="objective-box">
        <span class="objective-label sans">Versión objetiva</span>
        <p class="story-resumen">{{ story.analysis.resumen }}</p>
      </div>

      <!-- Headlines con score de sesgo -->
      <div class="headlines-list">
        <div class="headlines-header sans">
          <span>Titular</span>
          <span class="bias-legend">Sesgo <span class="bias-scale">0→10</span></span>
        </div>
        {% for h in story.headlines %}
        <a class="headline-row" href="{{ h.url }}" target="_blank" rel="noopener noreferrer">
          <span class="source-chip sans" style="background:{{ h.source_color }};color:{{ h.source_text_color }};">{{ h.source_short }}</span>
          <span class="headline-text">{{ h.title }}</span>
          <span class="headline-right">
            <span class="bias-score bias-score-{{ h.score }}" title="{{ h.score_reason }}">{{ h.score }}</span>
            <span class="headline-time sans">{{ h.pub_date|timeago }}</span>
            <span class="ext-icon">↗</span>
          </span>
        </a>
        {% endfor %}
      </div>

      <!-- Coincidencias y diferencias -->
      {% if story.analysis.coincidencias or story.analysis.diferencias %}
      <div class="story-insights sans">
        {% if story.analysis.coincidencias %}
        <div class="insight-block">
          <span class="insight-label agree">Todos coinciden en</span>
          <ul class="insight-list">
            {% for c in story.analysis.coincidencias %}<li>{{ c }}</li>{% endfor %}
          </ul>
        </div>
        {% endif %}
        {% if story.analysis.diferencias %}
        <div class="insight-block">
          <span class="insight-label differ">Difieren en</span>
          <ul class="insight-list">
            {% for d in story.analysis.diferencias %}<li>{{ d }}</li>{% endfor %}
          </ul>
        </div>
        {% endif %}
      </div>
      {% endif %}

    </article>
    {% endfor %}
  </section>
  {% endfor %}

  {% else %}
  <div class="empty-state">
    <p class="sans">Sin noticias comparadas hoy. Volvé mañana a las 7am.</p>
  </div>
  {% endif %}
</main>

<footer id="site-footer">
  <div class="footer-inner sans">
    <span>Actualizado el {{ last_update_date }} a las {{ last_update_time }} · © {{ year }}</span>
    <span class="footer-links">
      <a href="data/stories.json">JSON</a>
      <a href="sitemap.xml">Sitemap</a>
    </span>
  </div>
</footer>

<script src="assets/js/main.js"></script>
</body>
</html>
