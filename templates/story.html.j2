<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ story.topic }} — Contrapunto UY</title>
  <meta name="description" content="{{ story.analysis.resumen[:160] }}">
  <link rel="canonical" href="{{ base_url }}/story/{{ story.id }}.html">

  <!-- OpenGraph -->
  <meta property="og:title" content="{{ story.topic }}">
  <meta property="og:description" content="{{ story.analysis.resumen[:200] }}">
  <meta property="og:type" content="article">
  <meta property="og:url" content="{{ base_url }}/story/{{ story.id }}.html">

  <link rel="stylesheet" href="../assets/css/style.css">
</head>
<body>

<header id="site-header">
  <div class="header-inner">
    <div class="header-top">
      <a href="../" class="site-title serif" style="text-decoration:none;">Contra<span>punto</span> UY</a>
      <p class="site-tagline">La misma noticia, distintas voces</p>
    </div>
  </div>
</header>

<main>
  <div class="story-detail">

    <a class="back-link sans" href="../">← Volver a todas las noticias</a>

    <div class="story-detail-header">
      <span class="story-category sans">{{ story.category }}</span>
      <h1 class="story-detail-topic serif">{{ story.topic }}</h1>
      <p class="story-detail-meta sans">{{ story.sources_count }} medios · {{ last_update_date }}</p>
    </div>

    <!-- Headlines card -->
    <div class="detail-card">
      <div class="headlines-section" style="padding-top:0.5rem;">
        <p class="headlines-label sans" style="padding-top:0.75rem;">Titulares por medio</p>
        {% for h in story.headlines %}
        <a class="headline-row"
           href="{{ h.url }}"
           target="_blank"
           rel="noopener noreferrer">
          <span class="source-label">
            <span class="source-dot" style="background:{{ h.source_color }};"></span>
            <span class="source-name-text sans">{{ h.source_name }}</span>
          </span>
          <span class="headline-text">{{ h.title }}</span>
          <span class="headline-link-icon">↗</span>
        </a>
        {% endfor %}
      </div>

      <!-- Spectrometer -->
      <div class="spectrometer-section">
        <p class="spectro-heading sans">Nivel de tendenciosidad</p>
        <div class="spectro-wrapper">
          <span class="spectro-label left sans">◀ Neutral</span>
          <div class="spectro-track">
            <div class="spectro-gradient"></div>
            {% for pct in [10,20,30,40,50,60,70,80,90] %}
            <div class="spectro-tick" style="left:{{ pct }}%"></div>
            {% endfor %}
            {% for h in story.headlines %}
            <div class="spectro-dot"
                 style="left:{{ h.score_pct }}%;background:{{ h.source_color }};"
                 data-tooltip="{{ h.source_short }}: {{ h.score }}/10 — {{ h.score_reason|truncate_chars(60) }}">
            </div>
            {% endfor %}
          </div>
          <span class="spectro-label right sans">Tendencioso ▶</span>
        </div>

        <!-- Score detail table -->
        <div style="margin-top:1rem;">
          {% for h in story.headlines %}
          <div style="display:flex;align-items:center;gap:0.6rem;margin-bottom:0.4rem;font-size:0.78rem;font-family:'Inter',sans-serif;">
            <span class="source-badge sans"
                  style="background:{{ h.source_color }};color:{{ h.source_text_color }};width:36px;height:20px;font-size:0.58rem;">
              {{ h.source_short }}
            </span>
            <span style="width:30px;font-weight:600;color:var(--ink-muted);">{{ h.score }}/10</span>
            <span style="color:var(--ink-muted);">{{ h.score_reason }}</span>
          </div>
          {% endfor %}
        </div>
      </div>
    </div>

    <!-- Full analysis card -->
    <div class="detail-card" style="padding:1.5rem;">
      <div class="analysis-logo serif" style="font-size:1rem;margin-bottom:1rem;">✦ Análisis objetivo de Contrapunto UY</div>
      <p class="analysis-resumen" style="font-size:0.95rem;line-height:1.75;">{{ story.analysis.resumen }}</p>
      {% if story.analysis.coincidencias or story.analysis.diferencias %}
      <div class="analysis-points sans" style="margin-top:1.25rem;">
        {% if story.analysis.coincidencias %}
        <h4>En qué coinciden</h4>
        <ul>{% for c in story.analysis.coincidencias %}<li>{{ c }}</li>{% endfor %}</ul>
        {% endif %}
        {% if story.analysis.diferencias %}
        <h4>Diferencias de enfoque</h4>
        <ul>{% for d in story.analysis.diferencias %}<li>{{ d }}</li>{% endfor %}</ul>
        {% endif %}
      </div>
      {% endif %}
      <p class="analysis-disclaimer">
        Análisis generado automáticamente con IA (Claude de Anthropic). No reemplaza la lectura de las notas originales.
      </p>
    </div>

    <a class="back-link sans" href="../">← Volver a todas las noticias</a>

  </div>
</main>

<footer id="site-footer">
  <div class="footer-inner">
    <div>
      <div class="footer-brand serif">Contra<span>punto</span> UY</div>
      <div style="margin-top:0.25rem;">© {{ year }}</div>
    </div>
  </div>
</footer>

<script src="../assets/js/main.js"></script>
</body>
</html>
